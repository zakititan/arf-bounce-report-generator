{
  "manifest_version": 3,
  "name": "Report Generator → JIRA",
  "version": "2.0",
  "description": "Auto-creates JIRA tickets from ARF & Bounce Report Generator",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://jira.directi.com/*", "https://docs.google.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://arf-bounce-report-generator.vercel.app/*", "https://*.vercel.app/*"],
      "js": ["content-webapp.js"]
    },
    {
      "matches": ["https://jira.directi.com/*"],
      "js": ["content-jira.js"]
    },
    {
      "matches": ["https://abusedesk.ops.titan.email/*"],
      "js": ["content-abusedesk.js"]
    },
    {
      "matches": ["https://docs.google.com/spreadsheets/*"],
      "js": ["content-sheet.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
