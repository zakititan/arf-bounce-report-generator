{
  "manifest_version": 3,
  "name": "Report Generator → JIRA",
  "version": "4.2",
  "description": "Auto-creates JIRA tickets from Report Generator (ARF, Bounce, SMTP Suspension)",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://jira.directi.com/*", "https://admin.titan.email/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://arf-bounce-report-generator.vercel.app/*", "https://*.vercel.app/*"],
      "js": ["content-webapp.js"]
    },
    {
      "matches": ["https://jira.directi.com/*"],
      "js": ["content-jira.js"]
    },
    {
      "matches": ["https://abusedesk.ops.titan.email/*"],
      "js": ["content-abusedesk.js"]
    },
    {
      "matches": ["https://admin.titan.email/*"],
      "js": ["content-partner-panel.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
